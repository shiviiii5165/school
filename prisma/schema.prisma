generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model School {
  id        String   @id @default(cuid())
  name      String
  address   String
  phone     String
  email     String
  logo      String?
  createdAt DateTime @default(now())
}

model User {
  id        String   @id @default(cuid())
  regId     String   @unique // e.g. STU-2024-0042, TCH-001
  name      String
  email     String   @unique
  phone     String
  password  String // hashed
  role      String // ADMIN, TEACHER, STUDENT, PARENT
  avatar    String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  student       Student?
  parent        Parent?
  teacher       Teacher?
  notifications Notification[]
  
  installmentPlansCreated InstallmentPlan[]
  paymentsReceived        Payment[]
}

model Student {
  id                   String    @id @default(cuid())
  userId               String    @unique
  user                 User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  rollNo               String
  classId              String
  class                Class     @relation(fields: [classId], references: [id])
  fatherName           String
  motherName           String
  fatherPhone          String
  motherPhone          String
  address              String
  dateOfBirth          DateTime
  admissionDate        DateTime
  parentId             String?
  parent               Parent?   @relation(fields: [parentId], references: [id])
  isSuspended          Boolean   @default(false)
  suspendedReason      String?
  suspendedAt          DateTime?
  suspendedFrom        DateTime?
  suspendedUntil       DateTime?
  warningCount         Int       @default(0)
  lastWarningAt        DateTime?
  lastWarningNote      String?
  attendancePercentage Float     @default(100)
  examEligible         Boolean   @default(true)
  detainedAt           DateTime?
  detainedReason       String?
  detainedBy           String? // adminId
  hasTransport         Boolean   @default(false)
  transportZone        String?

  disciplineReports DisciplineReport[]
  attendanceRecords Attendance[]
  attendanceSummary AttendanceSummary?
  examResults       ExamResult[]
  examSummaries     ExamSummary[]
  hallTickets       HallTicket[]
  feeRecords        FeeRecord[]
  payments          Payment[]
  installmentPlans  InstallmentPlan[]
  creditWallet      CreditWallet?
}

model Parent {
  id       String    @id @default(cuid())
  userId   String    @unique
  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  students Student[]
}

model Teacher {
  id       String    @id @default(cuid())
  userId   String    @unique
  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  subjects Subject[]
  classes  Class[]
  joinDate DateTime
  salary   Float?

  reportedDisciplines DisciplineReport[]
  timetablePeriods    TimetablePeriod[]
  DailyAttendanceLog  DailyAttendanceLog[]
}

model Class {
  id                 String               @id @default(cuid())
  name               String // e.g. "Class 10"
  section            String // e.g. "A"
  teacherId          String
  teacher            Teacher              @relation(fields: [teacherId], references: [id])
  students           Student[]
  subjects           Subject[]
  assignments        Assignment[]
  timetablePeriods   TimetablePeriod[]
  DailyAttendanceLog DailyAttendanceLog[]
  examSlots          ExamSlot[]
}

model Subject {
  id        String  @id @default(cuid())
  name      String
  code      String
  classId   String
  class     Class   @relation(fields: [classId], references: [id])
  teacherId String
  teacher   Teacher @relation(fields: [teacherId], references: [id])

  assignments      Assignment[]
  timetablePeriods TimetablePeriod[]
  examSlots        ExamSlot[]
}

model Attendance {
  id          String           @id @default(cuid())
  studentId   String
  student     Student          @relation(fields: [studentId], references: [id])
  classId     String
  date        DateTime         @db.Date
  status      AttendanceStatus
  markedBy    String // teacherId
  submittedAt DateTime         @default(now())
  headCount   Int? // teacher's manual head count

  @@unique([studentId, classId, date])
  @@index([classId, date])
  @@index([studentId, date])
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  BLOCKED
}

// Attendance summary (pre-computed, updated on each submission)
model AttendanceSummary {
  id                   String   @id @default(cuid())
  studentId            String   @unique
  student              Student  @relation(fields: [studentId], references: [id])
  totalClasses         Int      @default(0)
  presentCount         Int      @default(0)
  absentCount          Int      @default(0)
  lateCount            Int      @default(0)
  attendancePercentage Float    @default(100)
  lastUpdated          DateTime @default(now())
}

model DailyAttendanceLog {
  id            String   @id @default(cuid())
  classId       String
  class         Class    @relation(fields: [classId], references: [id])
  teacherId     String
  teacher       Teacher  @relation(fields: [teacherId], references: [id])
  date          DateTime @db.Date
  submittedAt   DateTime @default(now())
  totalStudents Int
  presentCount  Int
  absentCount   Int
  lateCount     Int      @default(0)
  blockedCount  Int      @default(0)
  headCount     Int

  @@unique([classId, date])
}

model Assignment {
  id          String       @id @default(cuid())
  title       String
  description String
  subjectId   String
  subject     Subject      @relation(fields: [subjectId], references: [id])
  classId     String
  class       Class        @relation(fields: [classId], references: [id])
  teacherId   String
  dueDate     DateTime
  maxMarks    Float
  fileUrl     String?
  createdAt   DateTime     @default(now())
  submissions Submission[]
}

model Submission {
  id           String     @id @default(cuid())
  assignmentId String
  assignment   Assignment @relation(fields: [assignmentId], references: [id])
  studentId    String
  fileUrl      String?
  submittedAt  DateTime   @default(now())
  marks        Float?
  feedback     String?
  gradedAt     DateTime?
}

model Result {
  id        String   @id @default(cuid())
  studentId String
  subjectId String
  examType  String // "Unit Test 1", "Mid Term", "Final"
  marks     Float
  maxMarks  Float
  grade     String
  remarks   String?
  createdAt DateTime @default(now())
}

model FeeRecord {
  id          String    @id @default(cuid())
  studentId   String
  amount      Float
  feeType     String // "Tuition", "Transport", "Library"
  dueDate     DateTime
  paidDate    DateTime?
  status      String    @default("PENDING") // PENDING, PAID, OVERDUE, PARTIAL
  receiptNo   String?
  paymentMode String?

  paidAmount         Float     @default(0)
  hasInstallmentPlan Boolean   @default(false)
  installmentPlanId  String?
  lastPaymentAt      DateTime?

  student            Student           @relation(fields: [studentId], references: [id])
  payments           Payment[]
  installmentPlans   InstallmentPlan[]
}

model InstallmentPlan {
  id               String   @id @default(cuid())
  feeRecordId      String
  studentId        String
  createdByAdminId String
  totalMonths      Int
  status           String   @default("ACTIVE") // ACTIVE, COMPLETED, DEFAULTED, CANCELLED
  createdAt        DateTime @default(now())

  feeRecord        FeeRecord             @relation(fields: [feeRecordId], references: [id])
  student          Student               @relation(fields: [studentId], references: [id])
  createdBy        User                  @relation(fields: [createdByAdminId], references: [id])
  schedules        InstallmentSchedule[]
}

model InstallmentSchedule {
  id                String    @id @default(cuid())
  planId            String
  installmentNumber Int
  amount            Float
  dueDate           DateTime
  status            String    @default("PENDING") // PENDING, PAID, OVERDUE
  paidAt            DateTime?
  paymentId         String?

  plan              InstallmentPlan @relation(fields: [planId], references: [id])
  payments          Payment[]       @relation("SchedulePayments")
}

model Payment {
  id                    String   @id @default(cuid())
  studentId             String
  feeRecordId           String?
  installmentScheduleId String?
  amount                Float
  paymentMode           String // UPI, CARD, NET_BANKING, WALLET, CASH, CHEQUE, ADVANCE_WALLET
  transactionId         String?
  paymentDate           DateTime @default(now())
  receivedByAdminId     String?
  receiptNumber         String   @unique
  note                  String?
  status                String   @default("SUCCESS") // SUCCESS, PENDING, FAILED, REFUNDED
  createdAt             DateTime @default(now())

  student               Student              @relation(fields: [studentId], references: [id])
  feeRecord             FeeRecord?           @relation(fields: [feeRecordId], references: [id])
  installmentSchedule   InstallmentSchedule? @relation("SchedulePayments", fields: [installmentScheduleId], references: [id])
  receivedBy            User?                @relation(fields: [receivedByAdminId], references: [id])
}

model CreditWallet {
  id            String   @id @default(cuid())
  studentId     String   @unique
  balance       Float    @default(0)
  lastUpdatedAt DateTime @default(now())

  student       Student                   @relation(fields: [studentId], references: [id])
  transactions  CreditWalletTransaction[]
}

model CreditWalletTransaction {
  id                 String   @id @default(cuid())
  walletId           String
  type               String // CREDIT, DEBIT
  amount             Float
  reason             String
  relatedFeeRecordId String?
  createdAt          DateTime @default(now())

  wallet             CreditWallet @relation(fields: [walletId], references: [id])
}

model DisciplineReport {
  id          String    @id @default(cuid())
  studentId   String
  student     Student   @relation(fields: [studentId], references: [id])
  reportedBy  String // teacherId
  teacher     Teacher   @relation(fields: [reportedBy], references: [id])
  category    String
  description String
  status      String    @default("PENDING")
  adminNote   String?
  reviewedBy  String? // adminId
  reviewedAt  DateTime?
  actionTaken String?
  
  actionType      ActionType?
  suspendedFrom   DateTime?
  suspendedUntil  DateTime?
  warningNote     String?
  resolvedAt      DateTime?

  createdAt   DateTime  @default(now())
}

enum ActionType {
  WARNING
  SUSPENSION
  DISMISSED
}

model Notice {
  id        String   @id @default(cuid())
  title     String
  content   String
  audience  String[] // ["ALL", "TEACHERS", "STUDENTS", "PARENTS"]
  postedBy  String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
}

model Leave {
  id         String   @id @default(cuid())
  userId     String
  type       String // "Sick", "Casual", "Emergency"
  fromDate   DateTime
  toDate     DateTime
  reason     String
  status     String   @default("PENDING")
  approvedBy String?
  createdAt  DateTime @default(now())
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  message   String
  type      NotificationType
  isRead    Boolean          @default(false)
  link      String?
  metadata  Json?            // extra data (studentId, reportId etc)
  createdAt DateTime         @default(now())

  @@index([userId, isRead])
}

enum NotificationType {
  DISCIPLINE
  ATTENDANCE
  FEE
  ACADEMIC
  SYSTEM
}

model TimetablePeriod {
  id           String   @id @default(cuid())
  teacherId    String
  teacher      Teacher  @relation(fields: [teacherId], references: [id])
  classId      String
  class        Class    @relation(fields: [classId], references: [id])
  subjectId    String
  subject      Subject  @relation(fields: [subjectId], references: [id])
  dayOfWeek    Int // 1 (Monday) to 6 (Saturday)
  periodNumber Int // 1 to 7
  startTime    String // e.g., "08:00"
  endTime      String // e.g., "08:45"
  roomNumber   String
  createdAt    DateTime @default(now())

  @@unique([teacherId, dayOfWeek, periodNumber])
  @@index([teacherId])
  @@index([classId])
}

model SystemSettings {
  id            String  @id @default("singleton")
  schoolName    String
  schoolEmail   String
  schoolPhone   String?
  schoolAddress String?

  minimumAttendance  Int @default(75)
  detentionThreshold Int @default(75)

  gradingSystem String @default("PERCENTAGE")

  enableEmailAlerts Boolean @default(true)
  enableSMSAlerts   Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model FeeType {
  id           String  @id @default(cuid())
  name         String
  amount       Float
  frequency    String // MONTHLY / ANNUAL / ONE_TIME
  applicableTo String  @default("ALL")
  description  String?
  isActive     Boolean @default(true)
}

// ═══════════════════════════════════════════════════════════════
// EXAMINATION SYSTEM
// ═══════════════════════════════════════════════════════════════

enum ExamType {
  UNIT_TEST_1
  UNIT_TEST_2
  MID_TERM
  PRE_BOARD
  FINAL
  PRACTICAL
}

enum ExamStatus {
  DRAFT
  SCHEDULED
  ONGOING
  MARKS_ENTRY
  COMPLETED
}

model Exam {
  id            String     @id @default(cuid())
  name          String
  type          ExamType
  academicYear  String     // "2025-26"
  status        ExamStatus @default(DRAFT)
  startDate     DateTime
  endDate       DateTime
  defaultPassPct Float     @default(33)
  createdBy     String     // adminId
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  slots         ExamSlot[]
  results       ExamResult[]
  summaries     ExamSummary[]
  hallTickets   HallTicket[]
}

model ExamSlot {
  id         String   @id @default(cuid())
  examId     String
  exam       Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)
  classId    String
  class      Class    @relation(fields: [classId], references: [id])
  subjectId  String
  subject    Subject  @relation(fields: [subjectId], references: [id])
  date       DateTime @db.Date
  startTime  String   // "09:00"
  endTime    String   // "12:00"
  room       String
  maxMarks   Float
  passMarks  Float    @default(33)
  isLocked   Boolean  @default(false)

  results    ExamResult[]

  @@unique([examId, classId, subjectId])
  @@unique([classId, date, startTime])
}

model ExamResult {
  id        String   @id @default(cuid())
  examId    String
  exam      Exam     @relation(fields: [examId], references: [id])
  slotId    String
  slot      ExamSlot @relation(fields: [slotId], references: [id])
  studentId String
  student   Student  @relation(fields: [studentId], references: [id])
  marks     Float?   // null = not entered yet
  isAbsent  Boolean  @default(false)
  grade     String?  // auto-computed
  remarks   String?
  enteredBy String   // teacherId
  enteredAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([slotId, studentId])
  @@index([examId, studentId])
}

model ExamSummary {
  id            String   @id @default(cuid())
  examId        String
  exam          Exam     @relation(fields: [examId], references: [id])
  studentId     String
  student       Student  @relation(fields: [studentId], references: [id])
  totalMarks    Float    @default(0)
  maxMarks      Float    @default(0)
  percentage    Float    @default(0)
  grade         String   @default("")
  rank          Int?
  isPassed      Boolean  @default(false)
  isPublished   Boolean  @default(false)
  computedAt    DateTime @default(now())

  @@unique([examId, studentId])
}

model HallTicket {
  id          String   @id @default(cuid())
  examId      String
  exam        Exam     @relation(fields: [examId], references: [id])
  studentId   String
  student     Student  @relation(fields: [studentId], references: [id])
  isBlocked   Boolean  @default(false)
  blockReason String?
  blockedBy   String?  // adminId — null means auto-blocked
  generatedAt DateTime @default(now())

  @@unique([examId, studentId])
}
